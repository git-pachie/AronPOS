<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Receipt card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ Order Successful"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/green_500"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvReceiptOrderNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvReceiptDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="16dp" />

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="12dp" />

                    <!-- Items -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Items Ordered"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvReceiptItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="16dp" />

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="12dp" />

                    <!-- Totals -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Sub Total"
                            android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvReceiptSubTotal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₱0.00"
                            android:textStyle="bold" android:textSize="14sp" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Cash Given"
                            android:textColor="@color/text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tvReceiptCashGiven" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₱0.00"
                            android:textStyle="bold" android:textSize="14sp" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@color/green_bg"
                        android:padding="10dp" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Change"
                            android:textColor="@color/green_500" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvReceiptChange" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₱0.00"
                            android:textStyle="bold" android:textSize="18sp" android:textColor="@color/green_500" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- New Order button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewOrder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="12dp"
        android:text="NEW ORDER"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp" />

</LinearLayout>
