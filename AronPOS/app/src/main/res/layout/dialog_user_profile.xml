<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="24dp">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginBottom="12dp">

            <!-- Initials fallback -->
            <TextView
                android:id="@+id/tvDialogInitials"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:gravity="center"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="28sp"
                android:background="@drawable/bg_avatar_circle_large" />

            <!-- Profile photo -->
            <ImageView
                android:id="@+id/ivDialogPhoto"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle_large"
                android:visibility="gone"
                android:contentDescription="Profile photo" />
        </FrameLayout>

        <!-- Full name -->
        <TextView
            android:id="@+id/tvDialogFullName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Roles -->
        <TextView
            android:id="@+id/tvDialogRoles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Info rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Username -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="16sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDialogUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="✉️"
                android:textSize="16sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDialogEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Position -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="💼"
                android:textSize="16sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Position"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDialogPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Department -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="🏢"
                android:textSize="16sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDialogDepartment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Phone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="📞"
                android:textSize="16sp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDialogPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="4dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogLogout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/red_500"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            app:backgroundTint="@color/primary"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
