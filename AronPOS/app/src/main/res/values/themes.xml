<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AronPOS" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="android:statusBarColor">@color/primary_dark</item>

        <!-- Chip style -->
        <item name="chipStyle">@style/PosChip</item>
    </style>

    <style name="PosChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipCornerRadius">20dp</item>
    </style>
</resources>
