@model MenuItemViewModel
@{
    ViewData["Title"] = "Add Menu Item";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Items" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-plus-lg me-2 text-success"></i>Add Menu Item</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:680px;">
    <div class="card-body p-4">
        <form asp-action="CreateItem" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <!-- Product Image Upload -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Product Image <span class="text-muted fw-normal small">(optional)</span></label>
                <div class="d-flex align-items-center gap-3">
                    <!-- Preview box -->
                    <div id="imgPreviewWrap"
                         class="rounded-3 border d-flex align-items-center justify-content-center overflow-hidden flex-shrink-0"
                         style="width:100px;height:100px;background:var(--ra-table-head);">
                        <i class="bi bi-image text-muted fs-2" id="imgPlaceholder"></i>
                        <img id="imgPreview" src="" class="d-none w-100 h-100 object-fit-cover" alt="preview" />
                    </div>
                    <div>
                        <label for="imageInput" class="btn btn-outline-primary btn-sm mb-1">
                            <i class="bi bi-upload me-1"></i>Choose Image
                        </label>
                        <input type="file" id="imageInput" name="imageFile"
                               accept="image/jpeg,image/png,image/gif,image/webp"
                               class="d-none" onchange="previewImage(this)" />
                        <div class="text-muted small">JPG, PNG, GIF or WEBP — up to 1 GB</div>
                        <div id="imgFileName" class="small text-success mt-1"></div>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Caesar Salad" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        <input asp-for="Price" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MenuCategoryId" class="form-label fw-semibold"></label>
                    <select asp-for="MenuCategoryId" class="form-select"
                            asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="MenuCategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label">Available</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i>Save Item
                </button>
                <a asp-action="Items" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts")
    <script>
        function previewImage(input) {
            if (!input.files || !input.files[0]) return;
            var file = input.files[0];
            document.getElementById('imgFileName').textContent = '✓ ' + file.name;
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('imgPlaceholder').classList.add('d-none');
                var img = document.getElementById('imgPreview');
                img.src = e.target.result;
                img.classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        }
    </script>
}
