@model PriceHistoryViewModel
@{
    ViewData["Title"] = "Price History";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Items" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-info"></i>Price History</h4>
</div>

<div class="mb-3 p-3 bg-light rounded border" style="max-width:600px;">
    <div class="fw-semibold">@Model.ItemName</div>
    <div class="text-muted small">Current price: <span class="fw-bold text-success">@Model.CurrentPrice.ToString("C")</span></div>
</div>

<div class="card border-0 shadow-sm" style="max-width:700px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Old Price</th>
                        <th>New Price</th>
                        <th>Change</th>
                        <th>Changed By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.History)
                    {
                        var diff = entry.NewPrice - entry.OldPrice;
                        <tr>
                            <td class="text-muted small">@entry.ChangedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@entry.OldPrice.ToString("C")</td>
                            <td class="fw-semibold">@entry.NewPrice.ToString("C")</td>
                            <td>
                                @if (diff > 0)
                                {
                                    <span class="text-danger"><i class="bi bi-arrow-up-short"></i>@diff.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-success"><i class="bi bi-arrow-down-short"></i>@Math.Abs(diff).ToString("C")</span>
                                }
                            </td>
                            <td class="text-muted small">@entry.ChangedBy</td>
                        </tr>
                    }
                    @if (!Model.History.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No price changes recorded yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
