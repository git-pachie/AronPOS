@model UpdatePriceViewModel
@{
    ViewData["Title"] = "Update Price";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Items" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-currency-dollar me-2 text-success"></i>Update Price</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:450px;">
    <div class="card-body p-4">
        <div class="mb-3 p-3 bg-light rounded">
            <div class="fw-semibold">@Model.ItemName</div>
            <div class="text-muted small">Current price: <span class="fw-bold text-success">@Model.CurrentPrice.ToString("C")</span></div>
        </div>

        <form asp-action="UpdatePrice" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="MenuItemId" type="hidden" />
            <input asp-for="ItemName" type="hidden" />
            <input asp-for="CurrentPrice" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-4">
                <label asp-for="NewPrice" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="NewPrice" class="form-control form-control-lg" placeholder="0.00" />
                </div>
                <span asp-validation-for="NewPrice" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i>Update Price
                </button>
                <a asp-action="Items" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts")
}
