@model List<RestaurantAdmin.Models.Order>
@{
    ViewData["Title"] = "Orders";
    int currentPage = ViewBag.CurrentPage;
    int totalPages  = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-primary"></i>Orders</h4>
    <span class="text-muted small">Submitted from Android POS</span>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-3 bg-primary bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;flex-shrink:0;">
                    <i class="bi bi-receipt fs-5 text-primary"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold lh-1">@ViewBag.TotalOrders</div>
                    <div class="text-muted small">Total Orders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-3 bg-success bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;flex-shrink:0;">
                    <i class="bi bi-cash-stack fs-5 text-success"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold lh-1">@((ViewBag.TotalRevenue as decimal? ?? 0).ToString("C"))</div>
                    <div class="text-muted small">Total Revenue</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-3 bg-warning bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;flex-shrink:0;">
                    <i class="bi bi-calendar-day fs-5 text-warning"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold lh-1">@ViewBag.TodayOrders</div>
                    <div class="text-muted small">Today's Orders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div class="rounded-3 bg-info bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;flex-shrink:0;">
                    <i class="bi bi-graph-up fs-5 text-info"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold lh-1">@((ViewBag.TodayRevenue as decimal? ?? 0).ToString("C"))</div>
                    <div class="text-muted small">Today's Revenue</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Search</label>
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control form-control-sm"
                       placeholder="Order number or cashier..." />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">From Date</label>
                <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">To Date</label>
                <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Orders table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Date &amp; Time</th>
                        <th>Cashier</th>
                        <th>Items</th>
                        <th>Sub Total</th>
                        <th>Cash Given</th>
                        <th>Change</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold text-primary">@order.OrderNumber</span>
                            </td>
                            <td class="text-muted small">
                                <div>@order.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                <div>@order.OrderDate.ToLocalTime().ToString("hh:mm tt")</div>
                            </td>
                            <td class="text-muted small">@(order.CashierName ?? "—")</td>
                            <td>
                                <span class="badge bg-secondary">@order.OrderItems.Count item(s)</span>
                            </td>
                            <td class="fw-semibold">@order.SubTotal.ToString("C")</td>
                            <td class="text-muted">@order.CashGiven.ToString("C")</td>
                            <td class="text-success fw-semibold">@order.Change.ToString("C")</td>
                            <td>
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>@order.Status
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="bi bi-receipt fs-1 d-block mb-2 opacity-25"></i>
                                No orders found. Submit an order from the Android POS app.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage - 1)"
                   asp-route-search="@ViewBag.Search"
                   asp-route-dateFrom="@ViewBag.DateFrom"
                   asp-route-dateTo="@ViewBag.DateTo">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-dateFrom="@ViewBag.DateFrom"
                       asp-route-dateTo="@ViewBag.DateTo">@i</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(currentPage + 1)"
                   asp-route-search="@ViewBag.Search"
                   asp-route-dateFrom="@ViewBag.DateFrom"
                   asp-route-dateTo="@ViewBag.DateTo">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
