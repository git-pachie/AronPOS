@model AssignRolesViewModel
@{
    ViewData["Title"] = "Assign Roles";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-shield-check me-2 text-primary"></i>Assign Roles</h4>
</div>

<div class="card border-0 shadow-sm" style="max-width:500px;">
    <div class="card-body p-4">
        <div class="mb-3 p-3 bg-light rounded">
            <div class="fw-semibold">@Model.FullName</div>
            <div class="text-muted small">@Model.UserEmail</div>
        </div>

        <form asp-action="AssignRoles" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="UserEmail" type="hidden" />
            <input asp-for="FullName" type="hidden" />

            <label class="form-label fw-semibold">Select Roles</label>
            <div class="border rounded p-3 bg-light mb-4">
                @for (int i = 0; i < Model.Roles.Count; i++)
                {
                    <div class="form-check">
                        <input type="checkbox"
                               name="Roles[@i].IsSelected"
                               value="true"
                               class="form-check-input"
                               id="role_@i"
                               @(Model.Roles[i].IsSelected ? "checked" : "") />
                        <input type="hidden" name="Roles[@i].RoleName" value="@Model.Roles[i].RoleName" />
                        <label class="form-check-label" for="role_@i">@Model.Roles[i].RoleName</label>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Roles
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
