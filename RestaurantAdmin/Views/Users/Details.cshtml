@model UserDetailsViewModel
@{
    ViewData["Title"] = "User Details";
    var initials = string.IsNullOrEmpty(Model.FullName) ? "?" :
        string.Concat(Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0].ToString().ToUpper()));
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2 text-primary"></i>User Details</h4>
</div>

<div class="row g-4">

    <!-- ── Left: Profile card ──────────────────────────────────────────────── -->
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center d-flex flex-column align-items-center">

                <!-- Avatar -->
                <div class="rounded-circle d-flex align-items-center justify-content-center mb-3 fw-bold text-white fs-3"
                     style="width:88px;height:88px;background:linear-gradient(135deg,#1565C0,#42A5F5);">
                    @initials
                </div>

                <h5 class="fw-bold mb-0">@Model.FullName</h5>

                @if (!string.IsNullOrEmpty(Model.Position))
                {
                    <div class="text-muted small mt-1">@Model.Position</div>
                }
                @if (!string.IsNullOrEmpty(Model.Department))
                {
                    <div class="small mt-1">
                        <span class="badge bg-primary bg-opacity-10 text-primary">@Model.Department</span>
                    </div>
                }

                <div class="text-muted small mt-2">@Model.Email</div>

                <!-- Status -->
                <div class="mt-3">
                    @if (Model.IsSuspended)
                    {
                        <span class="badge bg-danger px-3 py-2">
                            <i class="bi bi-slash-circle me-1"></i>Suspended
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>Active
                        </span>
                    }
                </div>

                <!-- Roles -->
                <div class="d-flex flex-wrap gap-1 justify-content-center mt-3">
                    @if (Model.Roles.Any())
                    {
                        foreach (var role in Model.Roles)
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">
                                <i class="bi bi-shield-check me-1"></i>@role
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted small">No roles assigned</span>
                    }
                </div>

                <hr class="w-100 my-3" />

                <!-- Quick stats -->
                <div class="w-100 text-start">
                    <div class="d-flex justify-content-between py-1 border-bottom">
                        <span class="text-muted small">Member Since</span>
                        <span class="small fw-semibold">@Model.CreatedAt.ToString("MMM yyyy")</span>
                    </div>
                    @if (Model.LastLoginAt.HasValue)
                    {
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Last Login</span>
                            <span class="small fw-semibold">@Model.LastLoginAt.Value.ToString("MMM dd, yyyy")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Phone</span>
                            <span class="small fw-semibold">@Model.PhoneNumber</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.City) || !string.IsNullOrEmpty(Model.Country))
                    {
                        <div class="d-flex justify-content-between py-1">
                            <span class="text-muted small">Location</span>
                            <span class="small fw-semibold">
                                @string.Join(", ", new[] { Model.City, Model.Country }.Where(s => !string.IsNullOrEmpty(s)))
                            </span>
                        </div>
                    }
                </div>

                <hr class="w-100 my-3" />

                <!-- Actions -->
                <div class="d-flex flex-column gap-2 w-100">
                    <a asp-action="EditProfile" asp-route-id="@Model.Id"
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-person-gear me-1"></i>Edit Profile
                    </a>
                    <a asp-action="AssignRoles" asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-shield-check me-1"></i>Assign Roles
                    </a>
                    <a asp-action="ResetPassword" asp-route-id="@Model.Id"
                       class="btn btn-outline-warning btn-sm">
                        <i class="bi bi-key me-1"></i>Reset Password
                    </a>
                    @if (Model.IsSuspended)
                    {
                        <form asp-action="Unsuspend" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-success btn-sm w-100"
                                    onclick="return confirm('Unsuspend this user?')">
                                <i class="bi bi-person-check me-1"></i>Unsuspend
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-action="Suspend" asp-route-id="@Model.Id"
                           class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-person-slash me-1"></i>Suspend
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right: Tabs ─────────────────────────────────────────────────────── -->
    <div class="col-lg-9">

        <!-- Tab nav -->
        <ul class="nav nav-tabs mb-3" id="userTabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#tabProfile">
                    <i class="bi bi-person me-1"></i>Profile
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#tabSecurity">
                    <i class="bi bi-shield-lock me-1"></i>Security
                </a>
            </li>
            @if (Model.IsSuspended)
            {
                <li class="nav-item">
                    <a class="nav-link text-danger" data-bs-toggle="tab" href="#tabSuspension">
                        <i class="bi bi-slash-circle me-1"></i>Suspension
                    </a>
                </li>
            }
        </ul>

        <div class="tab-content">

            <!-- ── Profile Tab ──────────────────────────────────────────── -->
            <div class="tab-pane fade show active" id="tabProfile">
                <div class="row g-3">

                    <!-- Personal info -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 text-uppercase small text-muted">
                                        <i class="bi bi-person me-2"></i>Personal Information
                                    </h6>
                                    <a asp-action="EditProfile" asp-route-id="@Model.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                </div>
                                <div class="row g-3">
                                    <div class="col-sm-4">
                                        <div class="text-muted small">First Name</div>
                                        <div class="fw-semibold">@(Model.FirstName ?? "—")</div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Last Name</div>
                                        <div class="fw-semibold">@(Model.LastName ?? "—")</div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Full Name</div>
                                        <div class="fw-semibold">@Model.FullName</div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Gender</div>
                                        <div class="fw-semibold">@(Model.Gender ?? "—")</div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Date of Birth</div>
                                        <div class="fw-semibold">
                                            @(Model.DateOfBirth.HasValue
                                                ? Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")
                                                : "—")
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Phone Number</div>
                                        <div class="fw-semibold">@(Model.PhoneNumber ?? "—")</div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="text-muted small">Email Address</div>
                                        <div class="fw-semibold">@Model.Email</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Work info -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3 text-uppercase small text-muted">
                                    <i class="bi bi-briefcase me-2"></i>Work Information
                                </h6>
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Department</div>
                                        <div class="fw-semibold">@(Model.Department ?? "—")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Position / Job Title</div>
                                        <div class="fw-semibold">@(Model.Position ?? "—")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Member Since</div>
                                        <div class="fw-semibold">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Last Login</div>
                                        <div class="fw-semibold">
                                            @(Model.LastLoginAt.HasValue
                                                ? Model.LastLoginAt.Value.ToString("MMMM dd, yyyy hh:mm tt")
                                                : "Never")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3 text-uppercase small text-muted">
                                    <i class="bi bi-geo-alt me-2"></i>Address
                                </h6>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <div class="text-muted small">Street Address</div>
                                        <div class="fw-semibold">@(Model.Address ?? "—")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">City</div>
                                        <div class="fw-semibold">@(Model.City ?? "—")</div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Country</div>
                                        <div class="fw-semibold">@(Model.Country ?? "—")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    @if (!string.IsNullOrEmpty(Model.ProfileNotes))
                    {
                        <div class="col-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <h6 class="fw-bold mb-3 text-uppercase small text-muted">
                                        <i class="bi bi-sticky me-2"></i>Notes
                                    </h6>
                                    <p class="mb-0" style="white-space:pre-line;">@Model.ProfileNotes</p>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>

            <!-- ── Security Tab ─────────────────────────────────────────── -->
            <div class="tab-pane fade" id="tabSecurity">
                <div class="row g-3">

                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3 text-uppercase small text-muted">
                                    <i class="bi bi-shield-lock me-2"></i>Account Security
                                </h6>
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Email Confirmed</div>
                                        <div class="mt-1">
                                            @if (Model.EmailConfirmed)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check me-1"></i>Confirmed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-exclamation me-1"></i>Not Confirmed</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Two-Factor Auth</div>
                                        <div class="mt-1">
                                            @if (Model.TwoFactorEnabled)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-shield-check me-1"></i>Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary"><i class="bi bi-shield me-1"></i>Disabled</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Failed Login Attempts</div>
                                        <div class="mt-1">
                                            @if (Model.AccessFailedCount > 0)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle me-1"></i>@Model.AccessFailedCount attempt(s)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">0 failures</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Account Lockout</div>
                                        <div class="mt-1">
                                            @if (Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.UtcNow)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lock me-1"></i>Locked until @Model.LockoutEnd.Value.ToLocalTime().ToString("hh:mm tt")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success"><i class="bi bi-unlock me-1"></i>Not Locked</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="text-muted small">User ID</div>
                                        <div class="fw-semibold font-monospace small mt-1 p-2 rounded"
                                             style="background:var(--ra-table-head);">
                                            @Model.Id
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Password reset -->
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="fw-semibold">Password</div>
                                    <div class="text-muted small">Reset this user's password directly.</div>
                                </div>
                                <a asp-action="ResetPassword" asp-route-id="@Model.Id"
                                   class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-key me-1"></i>Reset Password
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ── Suspension Tab ───────────────────────────────────────── -->
            @if (Model.IsSuspended)
            {
                <div class="tab-pane fade" id="tabSuspension">
                    <div class="card border-0 shadow-sm border-danger border-opacity-25">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3 text-danger text-uppercase small">
                                <i class="bi bi-slash-circle me-2"></i>Suspension Details
                            </h6>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <div class="text-muted small">Suspended On</div>
                                    <div class="fw-semibold">
                                        @(Model.SuspendedAt.HasValue
                                            ? Model.SuspendedAt.Value.ToString("MMMM dd, yyyy hh:mm tt")
                                            : "—")
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="text-muted small">Reason</div>
                                    <div class="fw-semibold mt-1 p-3 rounded"
                                         style="background:var(--ra-table-head);">
                                        @(string.IsNullOrEmpty(Model.SuspendReason)
                                            ? "No reason provided."
                                            : Model.SuspendReason)
                                    </div>
                                </div>
                                <div class="col-12">
                                    <form asp-action="Unsuspend" asp-route-id="@Model.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success"
                                                onclick="return confirm('Unsuspend this user?')">
                                            <i class="bi bi-person-check me-1"></i>Unsuspend Account
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
