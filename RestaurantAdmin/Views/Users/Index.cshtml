@model List<UserListViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Users</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i>Create User
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:56px;"></th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        @* compute initials for fallback avatar *@
                        var initials = string.IsNullOrEmpty(user.FullName) ? "?" :
                            string.Concat(user.FullName
                                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                .Take(2).Select(w => w[0].ToString().ToUpper()));

                        <tr>
                            <!-- Avatar -->
                            <td>
                                @if (!string.IsNullOrEmpty(user.ProfileImagePath))
                                {
                                    <img src="@user.ProfileImagePath"
                                         alt="@user.FullName"
                                         class="rounded-circle object-fit-cover border"
                                         style="width:42px;height:42px;" />
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                         style="width:42px;height:42px;font-size:0.85rem;
                                                background:linear-gradient(135deg,#1565C0,#42A5F5);">
                                        @initials
                                    </div>
                                }
                            </td>

                            <td class="fw-semibold">@user.FullName</td>
                            <td class="text-muted small">@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-secondary me-1">@role</span>
                                }
                                @if (!user.Roles.Any())
                                {
                                    <span class="text-muted small">No roles</span>
                                }
                            </td>
                            <td>
                                @if (user.IsSuspended)
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-slash-circle me-1"></i>Suspended
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Active
                                    </span>
                                }
                            </td>
                            <td class="text-muted small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@user.Id"
                                       class="btn btn-outline-info" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="AssignRoles" asp-route-id="@user.Id"
                                       class="btn btn-outline-secondary" title="Assign Roles">
                                        <i class="bi bi-shield-check"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="ResetPassword" asp-route-id="@user.Id"
                                       class="btn btn-outline-warning" title="Reset Password">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    @if (user.IsSuspended)
                                    {
                                        <form asp-action="Unsuspend" asp-route-id="@user.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-success"
                                                    title="Unsuspend"
                                                    onclick="return confirm('Unsuspend this user?')">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-action="Suspend" asp-route-id="@user.Id"
                                           class="btn btn-outline-danger" title="Suspend">
                                            <i class="bi bi-person-slash"></i>
                                        </a>
                                    }
                                    <form asp-action="Delete" asp-route-id="@user.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger"
                                                title="Delete"
                                                onclick="return confirm('Delete user @user.FullName? This cannot be undone.')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
