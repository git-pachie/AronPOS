@model SuspendUserViewModel
@{
    ViewData["Title"] = "Suspend User";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-person-slash me-2 text-danger"></i>Suspend User</h4>
</div>

<div class="card border-0 shadow-sm border-danger" style="max-width:500px;">
    <div class="card-body p-4">
        <div class="alert alert-warning py-2 small">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Suspending this account will immediately prevent the user from logging in.
        </div>

        <div class="mb-3 p-3 bg-light rounded">
            <div class="fw-semibold">@Model.FullName</div>
            <div class="text-muted small">@Model.UserEmail</div>
        </div>

        <form asp-action="Suspend" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="UserEmail" type="hidden" />
            <input asp-for="FullName" type="hidden" />

            <div class="mb-4">
                <label asp-for="Reason" class="form-label fw-semibold"></label>
                <textarea asp-for="Reason" class="form-control" rows="3"
                          placeholder="Optional: reason for suspension..."></textarea>
                <span asp-validation-for="Reason" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-person-slash me-1"></i>Suspend Account
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
